{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ],
  "timezone": "Etc/UTC",
  "schedule": [
    "* 0-5 * * 1"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Cargo dependency policy",
      "matchManagers": [
        "cargo"
      ],
      "rangeStrategy": "bump",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group low-risk patch updates",
      "matchManagers": [
        "cargo"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "groupName": "Cargo patch dependencies"
    },
    {
      "description": "Require approval for major updates",
      "matchManagers": [
        "cargo"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Treat pre-1.0 minor updates as potentially breaking",
      "matchManagers": [
        "cargo"
      ],
      "matchCurrentVersion": "/^0\\./",
      "matchUpdateTypes": [
        "minor"
      ],
      "dependencyDashboardApproval": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "* 0-5 1 * *"
    ]
  }
}
